{
  "name": "tg-alive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "browser": {
    "constants": "constants-browserify",
    "crypto": "crypto-browserify",
    "fs": false,
    "net": false,
    "os": "os-browserify/browser",
    "path": "path-browserify",
    "stream": "stream-browserify",
    "tls": false
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "worker:dev": "wrangler dev --config workers/tg-gateway/wrangler.toml --local --port 8787",
    "worker:deploy": "wrangler deploy --config workers/tg-gateway/wrangler.toml",
    "pages:deploy": "npm run build && wrangler pages deploy dist --project-name tg-alive-pages",
    "deploy": "npm run worker:deploy && npm run pages:deploy",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "big-integer": "^1.6.52",
    "buffer": "^6.0.3",
    "constants-browserify": "^1.0.0",
    "crypto-browserify": "^3.12.1",
    "events": "^3.3.0",
    "lucide-react": "^0.468.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stream-browserify": "^3.0.0",
    "telegram": "^2.26.22",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "wrangler": "^4.95.0"
  }
}
